# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: required for admin user management (list users, role updates)
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email: ευχές, αιτήματα, εγγραφή portal, newsletter, backup)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@karacrm.gr
# Προαιρετικό: δοκιμαστικό & εβδομαδιαίο backup
ADMIN_EMAIL=
# Προαιρετικό: προστασία cron (header Authorization: Bearer …)
# CRON_SECRET=
# CRM (Next app): canonical base για δημοσκοπήσεις, backup links, /profile, κ.λπ.
# Vercel production: https://crm.kkaragkounis.com — πρόσθεσε και domain `crm.kkaragkounis.com` στο ίδιο project
NEXT_PUBLIC_APP_URL=
# Προαιρετικό· Vercel production: https://crm.kkaragkounis.com (αν κενό → NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_CRM_URL=
# Portal πολιτών· Vercel production: https://kkaragkounis.com — domains `kkaragkounis.com` + `www.kkaragkounis.com` στο ίδιο project
NEXT_PUBLIC_PORTAL_URL=

# Web push (VAPID) — ίδιο public key και στο client
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Retell AI
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=

# Google Calendar OAuth (managers/admins: /schedule, /api/auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local: http://localhost:3000/... — Production CRM: https://crm.kkaragkounis.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Anthropic (AI βοηθός)
ANTHROPIC_API_KEY=

# WhatsApp Business (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
# Προαιρετικό: WABA id για GET message_templates
# WHATSAPP_WABA_ID=

# Προαιρετικό: user id (Supabase auth) για ραντεβού portal — αλλιώς χρησιμοποιείται ο πρώτος με Google tokens
# APPOINTMENT_CALENDAR_USER_ID=

# Telegram (πρωινό briefing — προαιρετικό· μπορείτε και crm_settings από Ρυθμίσεις)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Προαιρετικό: κεφαλίδα / μυστικό για ασφάλεια endpoint POST /api/telegram/briefing
# TELEGRAM_BRIEFING_SECRET=

# ElevenLabs — Conversational AI (φωνητική Αλεξάνδρα, signed URL αποκλειστικά στον server)
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
# Ίδιο shared secret: δημόσια API (GET /api/public/*) — κλειδί κεφαλίδας x-api-key
ELEVENLABS_API_SECRET=90d00faa6c685b03b7e2cc73d0ba52ce90a13e995a47771dac557c55b572fa8f
